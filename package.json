{
  "name": "openspec-workspace",
  "displayName": "OpenSpec Workspace",
  "description": "VS Code extension for OpenSpec spec-driven development workflow",
  "version": "1.0.0",
  "publisher": "oioi555",
  "icon": "media/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/oioi555/openspec-workspace.git"
  },
  "homepage": "https://github.com/oioi555/openspec-workspace#readme",
  "bugs": {
    "url": "https://github.com/oioi555/openspec-workspace/issues"
  },
  "license": "MIT",
  "qna": false,
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "OpenSpec Workspace",
      "properties": {
        "openspecWorkspace.commandSyntax": {
          "type": "string",
          "enum": [
            "default",
            "claudeCode"
          ],
          "enumItemLabels": [
            "Default",
            "Claude Code"
          ],
          "enumDescriptions": [
            "Use the standard OpenSpec slash-command format: /opsx-<command>.",
            "Use the Claude Code-specific slash-command format: /opsx:<command>."
          ],
          "default": "default",
          "markdownDescription": "Choose which slash-command syntax OpenSpec helper actions copy. `Default` uses the standard `/opsx-<command>` form, while `Claude Code` uses the special `/opsx:<command>` form."
        },
        "openspecWorkspace.expandedCommands.new": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "Show the expanded `new` command in OpenSpec explorer menus."
        },
        "openspecWorkspace.expandedCommands.bulkArchive": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "Show the expanded `bulk-archive` command in OpenSpec explorer menus."
        },
        "openspecWorkspace.expandedCommands.continue": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "Show the expanded `continue` command in OpenSpec explorer menus."
        },
        "openspecWorkspace.expandedCommands.fastForward": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "Show the expanded `ff` command in OpenSpec explorer menus."
        },
        "openspecWorkspace.expandedCommands.verify": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "Show the expanded `verify` command in OpenSpec explorer menus."
        },
        "openspecWorkspace.expandedCommands.sync": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "Show the expanded `sync` command in OpenSpec explorer menus."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "openspecWorkspace",
          "title": "OpenSpec Workspace",
          "icon": "media/sidebar-icon.png"
        }
      ]
    },
    "views": {
      "openspecWorkspace": [
        {
          "id": "openspecWorkspaceExplorer",
          "name": "OpenSpec Explorer",
          "when": "openspecWorkspace:initialized",
          "icon": "media/sidebar-icon.png"
        },
        {
          "id": "openspecWorkspaceCliTools",
          "name": "CLI Tools",
          "when": "openspecWorkspace:initialized",
          "icon": "media/sidebar-icon.png"
        },
        {
          "id": "openspecWorkspaceWelcome",
          "name": "OpenSpec Workspace",
          "when": "!openspecWorkspace:initialized",
          "icon": "media/sidebar-icon.png"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "openspecWorkspaceWelcome",
        "contents": "Open a folder to start using OpenSpec.\n\nLearn more about [OpenSpec](https://github.com/Fission-AI/OpenSpec)",
        "when": "!openspecWorkspace:hasWorkspaceFolder"
      },
      {
        "view": "openspecWorkspaceWelcome",
        "contents": "OpenSpec is not initialized in this workspace.\n[Initialize OpenSpec](command:openspecWorkspace.init)\n\nLearn more about [OpenSpec](https://github.com/Fission-AI/OpenSpec)",
        "when": "openspecWorkspace:hasWorkspaceFolder && !openspecWorkspace:initialized"
      }
    ],
    "commands": [
      {
        "command": "openspecWorkspace.viewDetails",
        "title": "View Details",
        "icon": "$(search)"
      },
      {
        "command": "openspecWorkspace.listChanges",
        "title": "Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "openspecWorkspace.init",
        "title": "Initialize OpenSpec",
        "icon": "$(rocket)"
      },
      {
        "command": "openspecWorkspace.openSettings",
        "title": "Open Settings",
        "icon": "$(gear)"
      },
      {
        "command": "openspecWorkspace.copyChangeName",
        "title": "Copy: Change Name",
        "icon": "$(clippy)"
      },
      {
        "command": "openspecWorkspace.copyChangeCommand.propose",
        "title": "Copy: Propose",
        "icon": "$(clippy)"
      },
      {
        "command": "openspecWorkspace.copyChangeCommand.explore",
        "title": "Copy: Explore",
        "icon": "$(clippy)"
      },
      {
        "command": "openspecWorkspace.copyChangeCommand.new",
        "title": "Copy: New",
        "icon": "$(clippy)"
      },
      {
        "command": "openspecWorkspace.copyChangeCommand.bulkArchive",
        "title": "Copy: Bulk Archive",
        "icon": "$(clippy)"
      },
      {
        "command": "openspecWorkspace.copyChangeCommand.apply",
        "title": "Copy: Apply",
        "icon": "$(clippy)"
      },
      {
        "command": "openspecWorkspace.copyChangeCommand.archive",
        "title": "Copy: Archive",
        "icon": "$(clippy)"
      },
      {
        "command": "openspecWorkspace.copyChangeCommand.continue",
        "title": "Copy: Continue",
        "icon": "$(clippy)"
      },
      {
        "command": "openspecWorkspace.copyChangeCommand.ff",
        "title": "Copy: Fast Forward",
        "icon": "$(clippy)"
      },
      {
        "command": "openspecWorkspace.copyChangeCommand.verify",
        "title": "Copy: Verify",
        "icon": "$(clippy)"
      },
      {
        "command": "openspecWorkspace.copyChangeCommand.sync",
        "title": "Copy: Sync",
        "icon": "$(clippy)"
      },
      {
        "command": "openspecWorkspace.runCliTool",
        "title": "Run CLI Tool",
        "icon": "$(terminal)"
      },
      {
        "command": "openspecWorkspace.openCliHelp",
        "title": "Open CLI Reference",
        "icon": "$(link-external)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "openspecWorkspace.openSettings",
          "when": "view == openspecWorkspaceExplorer && openspecWorkspace:initialized",
          "group": "navigation@1"
        },
        {
          "command": "openspecWorkspace.listChanges",
          "when": "view == openspecWorkspaceExplorer && openspecWorkspace:initialized",
          "group": "navigation@2"
        },
        {
          "command": "openspecWorkspace.init",
          "when": "view == openspecWorkspaceWelcome && openspecWorkspace:hasWorkspaceFolder && !openspecWorkspace:initialized",
          "group": "navigation@1"
        }
      ],
      "view/item/context": [
        {
          "command": "openspecWorkspace.copyChangeCommand.propose",
          "when": "view == openspecWorkspaceExplorer && viewItem == changes-root",
          "group": "clipboard@1"
        },
        {
          "command": "openspecWorkspace.copyChangeCommand.explore",
          "when": "view == openspecWorkspaceExplorer && viewItem == changes-root",
          "group": "clipboard@2"
        },
        {
          "command": "openspecWorkspace.copyChangeCommand.new",
          "when": "view == openspecWorkspaceExplorer && viewItem == changes-root && openspecWorkspace:expandedCommandNew",
          "group": "clipboard@3"
        },
        {
          "command": "openspecWorkspace.copyChangeCommand.bulkArchive",
          "when": "view == openspecWorkspaceExplorer && viewItem == changes-root && openspecWorkspace:expandedCommandBulkArchive",
          "group": "clipboard@4"
        },
        {
          "command": "openspecWorkspace.copyChangeName",
          "when": "view == openspecWorkspaceExplorer && viewItem == active-change",
          "group": "clipboard@5"
        },
        {
          "command": "openspecWorkspace.copyChangeCommand.apply",
          "when": "view == openspecWorkspaceExplorer && viewItem == active-change",
          "group": "clipboard@6"
        },
        {
          "command": "openspecWorkspace.copyChangeCommand.archive",
          "when": "view == openspecWorkspaceExplorer && viewItem == active-change",
          "group": "clipboard@7"
        },
        {
          "command": "openspecWorkspace.copyChangeCommand.continue",
          "when": "view == openspecWorkspaceExplorer && viewItem == active-change && openspecWorkspace:expandedCommandContinue",
          "group": "clipboard@8"
        },
        {
          "command": "openspecWorkspace.copyChangeCommand.ff",
          "when": "view == openspecWorkspaceExplorer && viewItem == active-change && openspecWorkspace:expandedCommandFastForward",
          "group": "clipboard@9"
        },
        {
          "command": "openspecWorkspace.copyChangeCommand.verify",
          "when": "view == openspecWorkspaceExplorer && viewItem == active-change && openspecWorkspace:expandedCommandVerify",
          "group": "clipboard@10"
        },
        {
          "command": "openspecWorkspace.copyChangeCommand.sync",
          "when": "view == openspecWorkspaceExplorer && viewItem == active-change && openspecWorkspace:expandedCommandSync",
          "group": "clipboard@11"
        },
        {
          "command": "openspecWorkspace.runCliTool",
          "when": "view == openspecWorkspaceCliTools && viewItem == cli-command",
          "group": "inline@1"
        },
        {
          "command": "openspecWorkspace.openCliHelp",
          "when": "view == openspecWorkspaceCliTools && viewItem == cli-help",
          "group": "inline@1"
        },
        {
          "command": "openspecWorkspace.copyChangeName",
          "when": "view == openspecWorkspaceExplorer && viewItem == completed-change",
          "group": "clipboard@12"
        }
      ]
    },
    "keybindings": []
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "package:vsix": "npx --yes @vscode/vsce package",
    "watch": "tsc -w",
    "pretest": "npm run compile && npm run lint && tsc -p ./tsconfig.test.json",
    "lint": "eslint src --ext ts",
    "test": "node ./out/test/test/runTest.js",
    "test:compile": "tsc -p ./ && npm run test"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/marked": "^5.0.2",
    "@types/mocha": "^10.0.1",
    "@types/node": "16.x",
    "@types/vscode": "^1.74.0",
    "@typescript-eslint/eslint-plugin": "^5.45.0",
    "@typescript-eslint/parser": "^5.45.0",
    "@vscode/test-electron": "^2.2.2",
    "eslint": "^8.28.0",
    "glob": "^8.1.0",
    "jsdom": "^27.0.1",
    "mocha": "^10.2.0",
    "typescript": "^4.9.3"
  },
  "dependencies": {
    "marked": "^5.0.0"
  }
}
